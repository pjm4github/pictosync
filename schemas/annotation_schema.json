{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pictosync.io/schemas/annotation_schema.json",
  "title": "PictoSync Annotation Schema",
  "description": "JSON Schema for diagram annotation items used in PictoSync for canvas, property panel, and AI extraction interchange.",
  "type": "object",
  "required": ["annotations"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version identifier",
      "enum": ["draft-1", "overlay-1.0", "overlay-2.0"]
    },
    "image": {
      "$ref": "#/$defs/imageInfo"
    },
    "background_png": {
      "type": "string",
      "description": "Path to the background PNG image"
    },
    "scene_rect": {
      "$ref": "#/$defs/sceneRect"
    },
    "annotations": {
      "type": "array",
      "description": "List of annotation items",
      "items": {
        "$ref": "#/$defs/annotationItem"
      }
    }
  },
  "$defs": {
    "imageInfo": {
      "type": "object",
      "description": "Information about the source image",
      "properties": {
        "width": {
          "type": "number",
          "minimum": 0,
          "description": "Image width in pixels"
        },
        "height": {
          "type": "number",
          "minimum": 0,
          "description": "Image height in pixels"
        },
        "path": {
          "type": "string",
          "description": "Path to the image file"
        }
      }
    },
    "sceneRect": {
      "type": "object",
      "description": "Scene rectangle bounds",
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "w": { "type": "number", "minimum": 0 },
        "h": { "type": "number", "minimum": 0 }
      }
    },
    "annotationItem": {
      "type": "object",
      "description": "A single annotation item",
      "required": ["kind"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for this annotation",
          "pattern": "^[a-zA-Z][a-zA-Z0-9_]*$"
        },
        "kind": {
          "type": "string",
          "enum": ["rect", "roundedrect", "ellipse", "line", "text", "hexagon", "cylinder", "blockarrow", "polygon", "curve", "orthocurve", "isocube", "seqblock", "port", "group"],
          "description": "The type of annotation item"
        },
        "geom": {
          "$ref": "#/$defs/geometry"
        },
        "children": {
          "type": "array",
          "description": "Child annotations for group items",
          "items": {
            "$ref": "#/$defs/annotationItem"
          }
        },
        "contents": {
          "$ref": "#/$defs/annotationContents"
        },
        "style": {
          "$ref": "#/$defs/styleDefinition"
        },
        "dsl": {
          "$ref": "#/$defs/dslMetadata"
        },
        "z": {
          "type": "integer",
          "default": 1000,
          "description": "Z-index for stacking order (0 = default, omitted when 0)"
        },
        "parent_id": {
          "type": "string",
          "description": "Annotation ID of the parent shape this port attaches to (port items only, empty string for parentless)"
        },
        "connections": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Set of annotation IDs of connected line/curve/orthocurve items (port items only)"
        },
        "ports": {
          "type": "array",
          "items": { "type": "string" },
          "readOnly": true,
          "default": [],
          "description": "Computed list of child port annotation IDs (read-only, derived from port parent_id relationships)"
        }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "rect" } } },
          "then": { "properties": { "geom": { "$ref": "#/$defs/rectGeometry" } } }
        },
        {
          "if": { "properties": { "kind": { "const": "roundedrect" } } },
          "then": { "properties": { "geom": { "$ref": "#/$defs/roundedRectGeometry" } } }
        },
        {
          "if": { "properties": { "kind": { "const": "ellipse" } } },
          "then": { "properties": { "geom": { "$ref": "#/$defs/rectGeometry" } } }
        },
        {
          "if": { "properties": { "kind": { "const": "line" } } },
          "then": {
            "properties": {
              "geom": { "$ref": "#/$defs/lineGeometry" },
              "style": { "$ref": "#/$defs/lineStyleDefinition" },
              "ports": {
                "type": "array",
                "items": { "type": "string" },
                "readOnly": true,
                "default": [],
                "description": "Connected port annotation IDs (read-only, computed)"
              }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "text" } } },
          "then": {
            "properties": {
              "geom": { "$ref": "#/$defs/pointGeometry" },
              "contents": { "$ref": "#/$defs/annotationContents" },
              "style": {
                "type": "object",
                "properties": {
                  "pen": { "type": "object", "properties": {
                    "color": { "type": "string", "default": "#000000" },
                    "width": { "type": "number", "default": 1 }
                  }}
                }
              }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "hexagon" } } },
          "then": {
            "properties": {
              "geom": { "$ref": "#/$defs/hexagonGeometry" },
              "style": {
                "type": "object",
                "properties": {
                  "pen": { "type": "object", "properties": {
                    "color": { "type": "string", "default": "#008B8B" }
                  }}
                }
              }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "cylinder" } } },
          "then": {
            "properties": {
              "geom": { "$ref": "#/$defs/cylinderGeometry" },
              "style": {
                "type": "object",
                "properties": {
                  "pen": { "type": "object", "properties": {
                    "color": { "type": "string", "default": "#8B008B" }
                  }}
                }
              }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "blockarrow" } } },
          "then": {
            "properties": {
              "geom": { "$ref": "#/$defs/blockArrowGeometry" },
              "style": {
                "type": "object",
                "properties": {
                  "pen": { "type": "object", "properties": {
                    "color": { "type": "string", "default": "#B8860B" }
                  }}
                }
              }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "curve" } } },
          "then": {
            "properties": {
              "geom": { "$ref": "#/$defs/curveGeometry" },
              "style": { "$ref": "#/$defs/lineStyleDefinition" },
              "ports": {
                "type": "array",
                "items": { "type": "string" },
                "readOnly": true,
                "default": [],
                "description": "Connected port annotation IDs (read-only, computed)"
              }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "orthocurve" } } },
          "then": {
            "properties": {
              "geom": { "$ref": "#/$defs/orthoCurveGeometry" },
              "style": { "$ref": "#/$defs/lineStyleDefinition" },
              "ports": {
                "type": "array",
                "items": { "type": "string" },
                "readOnly": true,
                "default": [],
                "description": "Connected port annotation IDs (read-only, computed)"
              }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "isocube" } } },
          "then": {
            "properties": {
              "geom": { "$ref": "#/$defs/isoCubeGeometry" },
              "style": {
                "type": "object",
                "properties": {
                  "pen": { "type": "object", "properties": {
                    "color": { "type": "string", "default": "#000000" }
                  }},
                  "fill": { "type": "object", "properties": {
                    "color": { "type": "string", "default": "#C8C8C8C8" }
                  }}
                }
              }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "seqblock" } } },
          "then": { "properties": { "geom": { "$ref": "#/$defs/seqblockGeometry" } } }
        },
        {
          "if": { "properties": { "kind": { "const": "port" } } },
          "then": {
            "required": ["parent_id"],
            "properties": {
              "geom": { "$ref": "#/$defs/portGeometry" },
              "parent_id": {
                "type": "string",
                "description": "Annotation ID of the parent shape this port attaches to (empty string for parentless)"
              },
              "connections": {
                "type": "array",
                "items": { "type": "string" },
                "default": [],
                "description": "Set of annotation IDs of connected line/curve/orthocurve items"
              }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "group" } } },
          "then": {
            "required": ["children"],
            "properties": {
              "children": {
                "type": "array",
                "items": { "$ref": "#/$defs/annotationItem" }
              }
            }
          }
        }
      ]
    },

    "geometry": {
      "type": "object",
      "description": "Geometry specification (varies by item kind)",
      "oneOf": [
        { "$ref": "#/$defs/rectGeometry" },
        { "$ref": "#/$defs/roundedRectGeometry" },
        { "$ref": "#/$defs/lineGeometry" },
        { "$ref": "#/$defs/pointGeometry" },
        { "$ref": "#/$defs/hexagonGeometry" },
        { "$ref": "#/$defs/cylinderGeometry" },
        { "$ref": "#/$defs/blockArrowGeometry" },
        { "$ref": "#/$defs/curveGeometry" },
        { "$ref": "#/$defs/orthoCurveGeometry" },
        { "$ref": "#/$defs/isoCubeGeometry" },
        { "$ref": "#/$defs/seqblockGeometry" }
      ]
    },

    "rectGeometry": {
      "type": "object",
      "description": "Rectangle geometry (rect, ellipse)",
      "required": ["x", "y", "w", "h"],
      "properties": {
        "x": { "type": "number", "description": "X position of top-left corner" },
        "y": { "type": "number", "description": "Y position of top-left corner" },
        "w": { "type": "number", "minimum": 0, "description": "Width" },
        "h": { "type": "number", "minimum": 0, "description": "Height" },
        "angle": { "type": "number", "default": 0, "description": "Rotation angle in degrees (clockwise, 0-360). Omitted when 0." }
      },
      "additionalProperties": false
    },

    "roundedRectGeometry": {
      "type": "object",
      "description": "Rounded rectangle geometry",
      "required": ["x", "y", "w", "h"],
      "properties": {
        "x": { "type": "number", "description": "X position of top-left corner" },
        "y": { "type": "number", "description": "Y position of top-left corner" },
        "w": { "type": "number", "minimum": 0, "description": "Width" },
        "h": { "type": "number", "minimum": 0, "description": "Height" },
        "adjust1": {
          "type": "number",
          "minimum": 0,
          "maximum": 200,
          "default": 10,
          "description": "Corner radius in pixels",
          "ui_label": "Radius",
          "ui_suffix": " px"
        },
        "angle": { "type": "number", "default": 0, "description": "Rotation angle in degrees (clockwise, 0-360). Omitted when 0." }
      },
      "additionalProperties": false
    },

    "lineGeometry": {
      "type": "object",
      "description": "Line geometry with start and end points",
      "required": ["x1", "y1", "x2", "y2"],
      "properties": {
        "x1": { "type": "number", "description": "Start point X" },
        "y1": { "type": "number", "description": "Start point Y" },
        "x2": { "type": "number", "description": "End point X" },
        "y2": { "type": "number", "description": "End point Y" }
      },
      "additionalProperties": false
    },

    "pointGeometry": {
      "type": "object",
      "description": "Point geometry for text placement",
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number", "description": "X position" },
        "y": { "type": "number", "description": "Y position" }
      },
      "additionalProperties": false
    },

    "hexagonGeometry": {
      "type": "object",
      "description": "Hexagon geometry with adjust1 control (indent ratio)",
      "required": ["x", "y", "w", "h"],
      "properties": {
        "x": { "type": "number", "description": "X position of top-left corner" },
        "y": { "type": "number", "description": "Y position of top-left corner" },
        "w": { "type": "number", "minimum": 0, "description": "Width" },
        "h": { "type": "number", "minimum": 0, "description": "Height" },
        "adjust1": {
          "type": "number",
          "minimum": 0,
          "maximum": 0.5,
          "default": 0.25,
          "description": "Horizontal indent ratio for top/bottom vertices (0.0-0.5)",
          "ui_label": "Indent",
          "ui_suffix": " %"
        },
        "angle": { "type": "number", "default": 0, "description": "Rotation angle in degrees (clockwise, 0-360). Omitted when 0." }
      },
      "additionalProperties": false
    },

    "cylinderGeometry": {
      "type": "object",
      "description": "Cylinder geometry with adjust1 control (cap ratio)",
      "required": ["x", "y", "w", "h"],
      "properties": {
        "x": { "type": "number", "description": "X position of top-left corner" },
        "y": { "type": "number", "description": "Y position of top-left corner" },
        "w": { "type": "number", "minimum": 0, "description": "Width" },
        "h": { "type": "number", "minimum": 0, "description": "Height" },
        "adjust1": {
          "type": "number",
          "minimum": 0.01,
          "maximum": 0.5,
          "default": 0.15,
          "description": "Cap ellipse height as ratio of total height (0.01-0.5)",
          "ui_label": "Cap",
          "ui_suffix": " %"
        },
        "angle": { "type": "number", "default": 0, "description": "Rotation angle in degrees (clockwise, 0-360). Omitted when 0." }
      },
      "additionalProperties": false
    },

    "blockArrowGeometry": {
      "type": "object",
      "description": "Block arrow geometry with adjust1 (shaft width) and adjust2 (head length) controls",
      "required": ["x", "y", "w", "h"],
      "properties": {
        "x": { "type": "number", "description": "X position of top-left corner" },
        "y": { "type": "number", "description": "Y position of top-left corner" },
        "w": { "type": "number", "minimum": 0, "description": "Width" },
        "h": { "type": "number", "minimum": 0, "description": "Height" },
        "adjust2": {
          "type": "number",
          "minimum": 10,
          "maximum": 1200,
          "default": 15,
          "description": "Arrow head length in pixels",
          "ui_label": "Head",
          "ui_suffix": " px"
        },
        "adjust1": {
          "type": "number",
          "minimum": 0.01,
          "maximum": 1.0,
          "default": 0.65,
          "description": "Shaft height as ratio of total height (0.0-0.9)",
          "ui_label": "Shaft",
          "ui_suffix": " %"
        },
        "angle": { "type": "number", "default": 0, "description": "Rotation angle in degrees (clockwise, 0-360). Omitted when 0." }
      },
      "additionalProperties": false
    },

    "curveNode": {
      "type": "object",
      "description": "A single node in a curve path",
      "required": ["cmd"],
      "properties": {
        "cmd": {
          "type": "string",
          "enum": ["M", "L", "H", "V", "C", "S", "Q", "T", "A", "Z"],
          "description": "SVG path command"
        },
        "x": { "type": "number", "description": "Endpoint X (0-1 relative)" },
        "y": { "type": "number", "description": "Endpoint Y (0-1 relative)" },
        "c1x": { "type": "number", "description": "First control point X (cubic)" },
        "c1y": { "type": "number", "description": "First control point Y (cubic)" },
        "c2x": { "type": "number", "description": "Second control point X (cubic)" },
        "c2y": { "type": "number", "description": "Second control point Y (cubic)" },
        "cx": { "type": "number", "description": "Control point X (quadratic)" },
        "cy": { "type": "number", "description": "Control point Y (quadratic)" },
        "rx": { "type": "number", "description": "Arc radius X" },
        "ry": { "type": "number", "description": "Arc radius Y" },
        "rotation": { "type": "number", "description": "Arc rotation in degrees" },
        "large_arc": { "type": "integer", "enum": [0, 1], "description": "Large arc flag" },
        "sweep": { "type": "integer", "enum": [0, 1], "description": "Sweep direction flag" }
      }
    },

    "curveGeometry": {
      "type": "object",
      "description": "Curve geometry with bounding box and path nodes",
      "required": ["x", "y", "w", "h", "nodes"],
      "properties": {
        "x": { "type": "number", "description": "Bounding box X" },
        "y": { "type": "number", "description": "Bounding box Y" },
        "w": { "type": "number", "minimum": 0, "description": "Bounding box width" },
        "h": { "type": "number", "minimum": 0, "description": "Bounding box height" },
        "nodes": {
          "type": "array",
          "description": "Path nodes with SVG-like commands",
          "items": { "$ref": "#/$defs/curveNode" },
          "minItems": 2
        },
        "adjust1": {
          "type": "number",
          "minimum": 0,
          "maximum": 200,
          "default": 0,
          "description": "Corner bend radius for H/V transitions in pixels",
          "ui_label": "Bend Radius",
          "ui_suffix": " px"
        },
        "angle": { "type": "number", "default": 0, "description": "Rotation angle in degrees (clockwise, 0-360). Omitted when 0." }
      }
    },

    "orthoCurveNode": {
      "type": "object",
      "description": "A single node in an orthogonal curve path (M/H/V only)",
      "required": ["cmd"],
      "properties": {
        "cmd": {
          "type": "string",
          "enum": ["M", "H", "V"],
          "description": "Orthogonal path command"
        },
        "x": { "type": "number", "description": "Endpoint X (0-1 relative)" },
        "y": { "type": "number", "description": "Endpoint Y (0-1 relative)" }
      }
    },

    "orthoCurveGeometry": {
      "type": "object",
      "description": "Orthogonal curve geometry with bounding box and M/H/V path nodes",
      "required": ["x", "y", "w", "h", "nodes"],
      "properties": {
        "x": { "type": "number", "description": "Bounding box X" },
        "y": { "type": "number", "description": "Bounding box Y" },
        "w": { "type": "number", "minimum": 0, "description": "Bounding box width" },
        "h": { "type": "number", "minimum": 0, "description": "Bounding box height" },
        "nodes": {
          "type": "array",
          "description": "Path nodes with orthogonal commands (M/H/V)",
          "items": { "$ref": "#/$defs/orthoCurveNode" },
          "minItems": 2
        },
        "adjust1": {
          "type": "number",
          "minimum": 0,
          "maximum": 200,
          "default": 10,
          "description": "Corner bend radius in pixels",
          "ui_label": "Bend Radius",
          "ui_suffix": " px"
        },
        "angle": { "type": "number", "default": 0, "description": "Rotation angle in degrees (clockwise, 0-360). Omitted when 0." }
      }
    },

    "isoCubeGeometry": {
      "type": "object",
      "description": "Isometric cube geometry with depth and angle controls",
      "required": ["x", "y", "w", "h"],
      "properties": {
        "x": { "type": "number", "description": "X position of top-left corner" },
        "y": { "type": "number", "description": "Y position of top-left corner" },
        "w": { "type": "number", "minimum": 0, "description": "Width" },
        "h": { "type": "number", "minimum": 0, "description": "Height" },
        "adjust1": {
          "type": "number",
          "minimum": 0,
          "maximum": 10000,
          "default": 30,
          "description": "Depth of isometric extrusion in pixels (runtime max = max bbox dimension)",
          "ui_label": "Depth",
          "ui_suffix": " px"
        },
        "adjust2": {
          "type": "number",
          "minimum": 0,
          "maximum": 360,
          "default": 135,
          "description": "Angle of isometric extrusion in degrees",
          "ui_label": "Angle",
          "ui_suffix": " °"
        },
        "angle": { "type": "number", "default": 0, "description": "Rotation angle in degrees (clockwise, 0-360). Omitted when 0." }
      },
      "additionalProperties": false
    },

    "seqblockGeometry": {
      "type": "object",
      "description": "Sequence block geometry with adjustable divider positions",
      "required": ["x", "y", "w", "h"],
      "properties": {
        "x": { "type": "number", "description": "X position of top-left corner" },
        "y": { "type": "number", "description": "Y position of top-left corner" },
        "w": { "type": "number", "minimum": 0, "description": "Width" },
        "h": { "type": "number", "minimum": 0, "description": "Height" },
        "adjust1": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "default": 0.5,
          "description": "First divider Y position as ratio of height (0.0-1.0)",
          "ui_label": "Divider 1",
          "ui_suffix": " %"
        },
        "adjust2": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Second divider Y position as ratio of height (0.0-1.0, omit if unused)",
          "ui_label": "Divider 2",
          "ui_suffix": " %"
        },
        "adjust3": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Third divider Y position as ratio of height (0.0-1.0, omit if unused)",
          "ui_label": "Divider 3",
          "ui_suffix": " %"
        },
        "angle": { "type": "number", "default": 0, "description": "Rotation angle in degrees (clockwise, 0-360). Omitted when 0." }
      },
      "additionalProperties": false
    },

    "portGeometry": {
      "type": "object",
      "description": "Port connector geometry — position on parent perimeter",
      "properties": {
        "t": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0,
          "description": "Position on parent perimeter as fraction of path length (0.0–1.0)"
        },
        "radius": {
          "type": "number",
          "minimum": 1,
          "default": 6,
          "description": "Port circle radius in pixels"
        },
        "port_type": {
          "type": "string",
          "enum": ["In", "Out", "InOut"],
          "default": "InOut",
          "description": "Port direction type"
        },
        "protocol": {
          "type": "string",
          "default": "",
          "description": "Protocol label for this port"
        },
        "x": { "type": "number", "description": "X position (parentless ports only)" },
        "y": { "type": "number", "description": "Y position (parentless ports only)" },
        "w": { "type": "number", "description": "Width (parentless ports only)" },
        "h": { "type": "number", "description": "Height (parentless ports only)" }
      },
      "additionalProperties": false
    },

    "annotationContents": {
      "type": "object",
      "description": "Rich-text document contents with frame layout. The 'blocks' array is the canonical content model. The legacy 'text' field (HTML string) is retained for backward compatibility with overlay-1.0 files but should not be written by overlay-2.0 producers.",
      "properties": {

        "frame": {
          "$ref": "#/$defs/textFrame",
          "description": "Layout of the text block within the shape bounding box — margins and alignment"
        },

        "default_format": {
          "$ref": "#/$defs/charFormat",
          "description": "Document-level character format defaults. Individual run formats are sparse overrides of these values."
        },

        "blocks": {
          "type": "array",
          "description": "Ordered list of paragraph blocks. Each block contains one or more inline runs. Empty array = no text content.",
          "items": { "$ref": "#/$defs/textBlock" }
        },

        "label": {
          "type": "string",
          "readOnly": true,
          "description": "Convenience alias (read-only): plain text of block 0 runs concatenated. Derived from blocks[0]; edit via the Contents tab text widget."
        },
        "tech": {
          "type": "string",
          "readOnly": true,
          "description": "Convenience alias (read-only): plain text of block 1 runs concatenated. Derived from blocks[1]; edit via the Contents tab text widget."
        },
        "note": {
          "type": "string",
          "readOnly": true,
          "description": "Convenience alias (read-only): plain text of block 2 runs concatenated. Derived from blocks[2]; edit via the Contents tab text widget."
        },

        "wrap": {
          "type": "boolean",
          "default": true,
          "description": "Whether text wraps within the frame bounds"
        },

        "text_box_width": {
          "type": "number",
          "minimum": 0,
          "default": 0,
          "description": "Override text box width for line labels (0 = use shape width minus margins)"
        },
        "text_box_height": {
          "type": "number",
          "minimum": 0,
          "default": 0,
          "description": "Override text box height for line labels (0 = use shape height minus margins)"
        },

        "text_anchor_v": {
          "type": "string",
          "enum": ["top", "middle", "bottom"],
          "default": "middle",
          "description": "Vertical placement of the text box relative to the anchor point on the line/curve"
        },

        "anchor_value": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "default": 50,
          "description": "Position along the line/curve path (0-100%) where the text box is anchored"
        },

        "text_box_border": {
          "type": "boolean",
          "default": true,
          "description": "Whether to draw the text box border stroke"
        },
        "text_box_border_color": {
          "type": "string",
          "default": "",
          "description": "Text box border stroke color (#RRGGBBAA hex, empty = default grey)"
        },
        "text_box_background_color": {
          "type": "string",
          "default": "",
          "description": "Text box background fill color (#RRGGBBAA hex, empty = white)"
        },

        "text": {
          "type": "string",
          "default": "",
          "description": "[DEPRECATED — overlay-1.0 only] Rich text content as HTML fragments. Ignored by overlay-2.0 readers when 'blocks' is present. Retained for backward-compatible loading only."
        },
        "halign": {
          "type": "string",
          "enum": ["left", "center", "right", "justified"],
          "default": "center",
          "description": "[DEPRECATED — overlay-1.0 only] Horizontal alignment. Superseded by frame.halign in overlay-2.0."
        },
        "valign": {
          "type": "string",
          "enum": ["top", "middle", "bottom"],
          "default": "top",
          "description": "[DEPRECATED — overlay-1.0 only] Vertical alignment. Superseded by frame.valign in overlay-2.0."
        },
        "spacing": {
          "type": "number",
          "minimum": 0,
          "maximum": 2,
          "default": 0,
          "description": "[DEPRECATED — overlay-1.0 only] Paragraph spacing in em units. Superseded by textBlock.space_after in overlay-2.0."
        },
        "color": {
          "$ref": "#/$defs/colorHex",
          "description": "[DEPRECATED — overlay-1.0 only] Text color. Superseded by default_format.color in overlay-2.0."
        },
        "font_family": {
          "type": "string",
          "default": "",
          "description": "[DEPRECATED — overlay-1.0 only] Font family. Superseded by default_format.font_family in overlay-2.0."
        },
        "font_size": {
          "type": "integer",
          "minimum": 6,
          "maximum": 72,
          "default": 12,
          "description": "[DEPRECATED — overlay-1.0 only] Base font size in points. Superseded by default_format.font_size in overlay-2.0."
        },
        "margin_left": {
          "type": "number",
          "minimum": 0,
          "default": 0,
          "description": "[DEPRECATED — overlay-1.0 only] Left margin in pixels. Superseded by frame.margin_left in overlay-2.0."
        },
        "margin_right": {
          "type": "number",
          "minimum": 0,
          "default": 0,
          "description": "[DEPRECATED — overlay-1.0 only] Right margin in pixels. Superseded by frame.margin_right in overlay-2.0."
        },
        "margin_top": {
          "type": "number",
          "minimum": 0,
          "default": 0,
          "description": "[DEPRECATED — overlay-1.0 only] Top margin in pixels. Superseded by frame.margin_top in overlay-2.0."
        },
        "margin_bottom": {
          "type": "number",
          "minimum": 0,
          "default": 0,
          "description": "[DEPRECATED — overlay-1.0 only] Bottom margin in pixels. Superseded by frame.margin_bottom in overlay-2.0."
        },
        "flow_type": {
          "type": "string",
          "enum": ["none", "tight", "wrap-points", "top-bottom"],
          "default": "none",
          "description": "[DEPRECATED — overlay-1.0 only] Text flow around embedded image. Superseded by textRun anchor sizing in overlay-2.0."
        },
        "image_url": {
          "type": "string",
          "default": "",
          "description": "[DEPRECATED — overlay-1.0 only] URL or path to an embedded image. Superseded by textRun type=anchor in overlay-2.0."
        },
        "image_anchor": {
          "type": "integer",
          "default": 0,
          "description": "[DEPRECATED — overlay-1.0 only] Image anchor position. Superseded by textRun type=anchor in overlay-2.0."
        }
      },
      "additionalProperties": true
    },

    "textFrame": {
      "type": "object",
      "description": "Controls how the text block is positioned and clipped inside the shape bounding box. Margin values define the inset content area. Alignment is applied after QTextDocument layout.",
      "properties": {
        "margin_left":   { "type": "number", "minimum": 0, "default": 4, "description": "Left inset margin in pixels" },
        "margin_right":  { "type": "number", "minimum": 0, "default": 4, "description": "Right inset margin in pixels" },
        "margin_top":    { "type": "number", "minimum": 0, "default": 4, "description": "Top inset margin in pixels" },
        "margin_bottom": { "type": "number", "minimum": 0, "default": 4, "description": "Bottom inset margin in pixels" },
        "valign": {
          "type": "string",
          "enum": ["top", "middle", "bottom"],
          "default": "top",
          "description": "Vertical alignment of the composed text block within the shape content area. Computed post-layout using QTextDocument.size().height() vs available frame height."
        },
        "halign": {
          "type": "string",
          "enum": ["left", "center", "right", "justified"],
          "default": "center",
          "description": "Default horizontal alignment applied to all paragraphs unless overridden by textBlock.halign."
        }
      },
      "additionalProperties": false
    },

    "charFormat": {
      "type": "object",
      "description": "Character-level formatting properties. Used both as document-level defaults (annotationContents.default_format) and as sparse per-run overrides (textRun.format). Only properties present in a run's format object override the document default — absent properties inherit from default_format.",
      "properties": {
        "font_family": {
          "type": "string",
          "description": "Font family name. Empty string = inherit system default sans-serif."
        },
        "font_size": {
          "type": "integer",
          "minimum": 6,
          "maximum": 144,
          "description": "Font size in points."
        },
        "bold":          { "type": "boolean", "description": "Bold weight." },
        "italic":        { "type": "boolean", "description": "Italic style." },
        "underline":     { "type": "boolean", "description": "Underline decoration." },
        "strikethrough": { "type": "boolean", "description": "Strikethrough decoration." },
        "color": {
          "$ref": "#/$defs/colorHex",
          "description": "Foreground text color."
        },
        "background_color": {
          "$ref": "#/$defs/colorHex",
          "description": "Character highlight / background color."
        },
        "superscript": { "type": "boolean", "description": "Superscript vertical alignment. Mutually exclusive with subscript." },
        "subscript":   { "type": "boolean", "description": "Subscript vertical alignment. Mutually exclusive with superscript." }
      },
      "additionalProperties": false
    },

    "textBlock": {
      "type": "object",
      "description": "A paragraph block — the block-level container in the document. Maps 1:1 to a QTextBlock. Contains an ordered list of inline runs. Paragraph-level properties here override frame-level defaults for this paragraph only.",
      "required": ["runs"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Session-stable identifier for pictosync delta tracking (e.g. 'b0', 'b1'). Generated at runtime, not persisted across save/load cycles."
        },
        "halign": {
          "type": "string",
          "enum": ["left", "center", "right", "justified"],
          "description": "Paragraph-level horizontal alignment override. When present, takes precedence over frame.halign for this paragraph only."
        },
        "line_spacing": {
          "type": "number",
          "minimum": 0.5,
          "maximum": 4.0,
          "default": 1.0,
          "description": "Line height multiplier. 1.0 = single spacing, 2.0 = double. Maps to QTextBlockFormat.setLineHeight(value * 100, ProportionalHeight)."
        },
        "space_before": {
          "type": "number",
          "minimum": 0,
          "default": 0,
          "description": "Space above this paragraph in pixels. Maps to QTextBlockFormat.setTopMargin()."
        },
        "space_after": {
          "type": "number",
          "minimum": 0,
          "default": 0,
          "description": "Space below this paragraph in pixels. Maps to QTextBlockFormat.setBottomMargin()."
        },
        "runs": {
          "type": "array",
          "description": "Ordered list of inline runs within this paragraph. Each run is either a text span or an anchored graphic object. Maps to QTextFragment items within the QTextBlock.",
          "items": { "$ref": "#/$defs/textRun" },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },

    "textRun": {
      "type": "object",
      "description": "An inline run within a paragraph. Discriminated by 'type': either a character text span or an anchored graphic object. Text runs map to QTextFragment. Anchor runs map to a QTextObjectInterface custom object inserted via QTextCursor with a custom QTextCharFormat carrying the object type.",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["text", "anchor"],
          "description": "Run discriminator. 'text' = character content span. 'anchor' = inline embedded graphic item."
        },
        "id": {
          "type": "string",
          "description": "Session-stable run identifier for pictosync delta tracking (e.g. 'b0r2'). Generated at runtime, not persisted across save/load cycles."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "text" } },
            "required": ["type"]
          },
          "then": {
            "required": ["text"],
            "properties": {
              "text": {
                "type": "string",
                "description": "The character content of this run. May contain any Unicode text including newline characters for soft line breaks within a paragraph."
              },
              "format": {
                "$ref": "#/$defs/charFormat",
                "description": "Sparse character format overrides for this run. Only properties that differ from annotationContents.default_format need to be present. Qt coalesces adjacent runs with identical effective formats automatically."
              }
            }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "anchor" } },
            "required": ["type"]
          },
          "then": {
            "required": ["anchor_id"],
            "properties": {
              "anchor_id": {
                "type": "string",
                "description": "Annotation ID of the embedded graphic item. Must reference a valid 'id' in the top-level annotations array. The referenced item is rendered inline at this position in the text flow."
              },
              "sizing": {
                "type": "string",
                "enum": ["inline", "fixed"],
                "default": "inline",
                "description": "Sizing mode. 'inline' = render at the item's natural geometry size, flowing with text baseline. 'fixed' = render at explicit width/height overrides."
              },
              "width": {
                "type": "number",
                "minimum": 1,
                "description": "Display width in pixels. Used when sizing='fixed'. Ignored for sizing='inline'."
              },
              "height": {
                "type": "number",
                "minimum": 1,
                "description": "Display height in pixels. Used when sizing='fixed'. Ignored for sizing='inline'."
              },
              "baseline_offset": {
                "type": "number",
                "default": 0,
                "description": "Vertical shift from the text baseline in pixels. Positive values shift the object upward. Useful for aligning small icons with adjacent text."
              }
            }
          }
        }
      ]
    },

    "colorHex": {
      "type": "string",
      "pattern": "^#([0-9A-Fa-f]{6}|[0-9A-Fa-f]{8})$",
      "description": "Hex color string (#RRGGBB or #RRGGBBAA)"
    },

    "penStyle": {
      "type": "object",
      "description": "Pen/stroke style",
      "properties": {
        "color": { "$ref": "#/$defs/colorHex", "default": "#FF0000" },
        "width": { "type": "number", "minimum": 0, "default": 2, "description": "Stroke width in pixels" },
        "dash": {
          "type": "string",
          "enum": ["solid", "dashed"],
          "default": "solid",
          "description": "Line dash style"
        },
        "dash_pattern_length": {
          "type": "number",
          "minimum": 4,
          "maximum": 100,
          "default": 30,
          "description": "Total length of dash pattern in pixels (when dash is 'dashed')"
        },
        "dash_solid_percent": {
          "type": "number",
          "minimum": 1,
          "maximum": 99,
          "default": 50,
          "description": "Percentage of pattern that is solid (when dash is 'dashed')"
        }
      }
    },

    "fillStyle": {
      "type": "object",
      "description": "Fill/background style",
      "properties": {
        "color": { "$ref": "#/$defs/colorHex", "default": "#00000000" }
      }
    },

    "styleDefinition": {
      "type": "object",
      "description": "Complete style definition for an item (pen + fill only; text properties live in contents)",
      "properties": {
        "pen":  { "$ref": "#/$defs/penStyle" },
        "fill": { "$ref": "#/$defs/fillStyle" }
      }
    },

    "dslMetadata": {
      "type": "object",
      "description": "Domain-specific language metadata (meta.dsl). Contains a tool hint and one domain sub-object (c4, uml, d2, …). Stored as a standalone $defs entry — NOT referenced from annotationMeta.properties — so _extract_defaults won't inject empty dsl objects onto every annotation.",
      "properties": {
        "tool": {
          "type": "string",
          "enum": ["mermaid", "plantuml", "d2"],
          "description": "Rendering tool that produced this annotation"
        },
        "c4": { "$ref": "#/$defs/dslC4" }
      },
      "additionalProperties": true
    },

    "dslC4": {
      "type": "object",
      "description": "C4 model metadata. Shapes carry type+alias+parent; boundaries carry type='boundary'+alias+boundary_type+parent; relationships carry rel_type+from+to.",
      "properties": {
        "type": {
          "type": "string",
          "description": "C4 element type. Shapes: person, system, container, component and their variants. Boundaries always use 'boundary'.",
          "enum": [
            "person", "external_person",
            "system", "system_db", "system_queue",
            "external_system", "external_system_db", "external_system_queue",
            "container", "container_db", "container_queue",
            "external_container", "external_container_db", "external_container_queue",
            "component", "component_db", "component_queue",
            "external_component", "external_component_db", "external_component_queue",
            "boundary"
          ]
        },
        "alias": {
          "type": "string",
          "description": "Unique identifier for this element within the C4 diagram (e.g. 'spa', 'b1')"
        },
        "parent": {
          "type": "string",
          "description": "Alias of the enclosing boundary. Omitted when the element is at global scope."
        },
        "boundary_type": {
          "type": "string",
          "description": "Classification of a boundary element (only present when type='boundary')",
          "enum": ["ENTERPRISE", "SYSTEM", "CONTAINER", "node", "nodeL", "nodeR"]
        },
        "rel_type": {
          "type": "string",
          "description": "Canonical relationship direction type",
          "enum": ["rel", "birel", "rel_b", "rel_u", "rel_d", "rel_l", "rel_r"]
        },
        "from": { "type": "string", "description": "Source element alias in a relationship" },
        "to":   { "type": "string", "description": "Target element alias in a relationship" }
      },
      "additionalProperties": true
    },

    "lineStyleDefinition": {
      "type": "object",
      "description": "Style definition for line items (includes arrow mode)",
      "properties": {
        "pen":  { "$ref": "#/$defs/penStyle" },
        "fill": { "$ref": "#/$defs/fillStyle" },
        "arrow": {
          "type": "string",
          "enum": ["none", "start", "end", "both"],
          "default": "none",
          "description": "Arrowhead mode"
        },
        "arrow_size": {
          "type": "number",
          "minimum": 4,
          "maximum": 50,
          "default": 12,
          "description": "Arrowhead size in pixels"
        }
      }
    }
  }
}